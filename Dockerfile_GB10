# ============================================================
# JaxMARL-HFT Docker Image
# ============================================================
# Supports ARM64 (DGX Spark GB10) and x86_64 systems with NVIDIA GPUs.
#
# Build:  make build
# Run:    make run            (opens interactive shell)
#         make ppo_2player gpu=0   (runs 2-player training on GPU 0)
#
# The Makefile mounts:
#   - The repo          -> /home/myuser/
#   - Your data dir     -> /home/myuser/data/
#   - Your scratch dir  -> /home/myuser/scratch/
#
# So inside the container, the default env config paths
# (alphatradePath="/home/myuser", dataPath="/home/myuser/data")
# work without modification.
#
# For WandB logging, set your API key before running:
#   export WANDB_API_KEY=<your-key>
#   make ppo_2player gpu=0
# Or pass it via docker run:
#   docker run -e WANDB_API_KEY=<your-key> ...
# ============================================================

FROM nvidia/cuda:13.0.1-runtime-ubuntu24.04

# Install system packages (including python3)
RUN apt-get update && \
    apt-get install -y \
    python3 python3-pip python3-venv \
    git wget tmux \
    apt-transport-https \
    ca-certificates \
    gnupg \
    libgl1 \
    p7zip-full \
    unrar \
    htop \
    graphviz

# Create user
ARG UID
ARG MYUSER
RUN useradd -m -u $UID -o --create-home ${MYUSER} 2>/dev/null; \
    echo "${MYUSER}:${MYUSER}" | chpasswd && \
    adduser ${MYUSER} sudo && \
    chown -R ${MYUSER}:${MYUSER} /home/${MYUSER}

# default workdir
WORKDIR /home/${MYUSER}/
COPY --chown=${MYUSER} --chmod=777 . .

# Install Python dependencies
# Install JAX with CUDA 13 support first, then the rest of requirements
RUN pip install --break-system-packages "jax[cuda13]" && \
    pip install --break-system-packages -r requirements.txt

# Install Go (used for WandB internals) — detect architecture
RUN ARCH=$(dpkg --print-architecture) && \
    if [ "$ARCH" = "arm64" ]; then GOARCH=arm64; else GOARCH=amd64; fi && \
    wget -q https://go.dev/dl/go1.24.5.linux-${GOARCH}.tar.gz && \
    rm -rf /usr/local/go && \
    tar -C /usr/local -xzf go1.24.5.linux-${GOARCH}.tar.gz && \
    rm go1.24.5.linux-${GOARCH}.tar.gz
ENV PATH="$PATH:/usr/local/go/bin"

USER ${MYUSER}

# JAX memory settings — prevent OOM by disabling full preallocation
ENV XLA_PYTHON_CLIENT_PREALLOCATE=false
ENV XLA_PYTHON_CLIENT_MEM_FRACTION=0.25
ENV TF_FORCE_GPU_ALLOW_GROWTH=true

# Ensure repo root is on the Python path
ENV PYTHONPATH="/home/${MYUSER}:$PYTHONPATH"

RUN git config --global --add safe.directory /home/${MYUSER}
